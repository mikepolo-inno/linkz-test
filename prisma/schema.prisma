generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  clerkUserId  String        @unique
  email        String?       @unique
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  payments     Payment[]
  reservations Reservation[]
  seats        Seat[]        @relation("SeatReservedBy")
  lockedSeats  Seat[]        @relation("SeatLockedBy")
  seatLocks    SeatLock[]
}

model Seat {
  id               String        @id @default(cuid())
  label            String        @unique
  status           String        @default("AVAILABLE")
  reservedByUserId String?
  reservedAt       DateTime?
  lockedByUserId   String?
  lockExpiresAt    DateTime?
  lockPaymentId    String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reservedBy       User?         @relation("SeatReservedBy", fields: [reservedByUserId], references: [id])
  lockedBy         User?         @relation("SeatLockedBy", fields: [lockedByUserId], references: [id])
  lockPayment      Payment?      @relation("SeatLockPayment", fields: [lockPaymentId], references: [id])
  payments         Payment[]
  reservation      Reservation?
  locks            SeatLock[]

  @@index([lockedByUserId])
  @@index([lockExpiresAt])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  seatId         String
  amountCents    Int
  currency       String        @default("USD")
  status         String   @default("PENDING")
  idempotencyKey String        @unique
  failureReason  String?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  seat           Seat          @relation(fields: [seatId], references: [id])
  lockedSeat     Seat?         @relation("SeatLockPayment")
  lock           SeatLock?
  events         PaymentEvent[]
  reservation    Reservation?

  @@index([userId])
  @@index([seatId])
}

model SeatLock {
  id         String    @id @default(cuid())
  userId     String
  seatId     String
  paymentId  String    @unique
  expiresAt  DateTime
  releasedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  seat       Seat      @relation(fields: [seatId], references: [id])
  payment    Payment   @relation(fields: [paymentId], references: [id])

  @@index([seatId, expiresAt])
  @@index([userId])
}

model PaymentEvent {
  id             String   @id @default(cuid())
  paymentId      String
  type           String
  status         String?
  source         String
  message        String?
  gatewayEventId String?  @unique
  payload        String?
  createdAt      DateTime @default(now())
  payment        Payment  @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([type])
}

model Reservation {
  id        String   @id @default(cuid())
  userId    String
  seatId    String   @unique
  paymentId String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  seat      Seat     @relation(fields: [seatId], references: [id])
  payment   Payment  @relation(fields: [paymentId], references: [id])

  @@index([userId])
}
